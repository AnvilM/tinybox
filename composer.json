{
  "name": "anvilm/tinybox",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "anvilm",
      "homepage": "https://github.com/AnvilM"
    }
  ],
  "autoload": {
    "psr-4": {
      "Application\\": "app/",
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php-di/php-di": "^7.1",
    "monolog/monolog": "^3.9",
    "symfony/console": "^7.3",
    "opis/json-schema": "^2.6",
    "guzzlehttp/guzzle": "^7.0",
    "league/climate": "^3.10",
    "ramsey/collection": "^2.1",
    "azjezz/psl": "^5.3",
    "geoip2/geoip2": "^3.3",
    "ramsey/uuid": "^4.9"
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
    "check": [
      "@analyse",
      "@test"
    ]
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "mockery/mockery": "^1.6"
  }
}
