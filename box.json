{
  "main": "tinybox.php",
  "output": "/build/app.phar",
  "compression": "GZ",
  "algorithm": "SHA512",
  "check-requirements": false,
  "directories": [
    "src",
    "app"
  ],
  "files": [
    "tinybox.php"
  ],
  "finder": [
    {
      "in": "vendor",
      "exclude": [
        "tests",
        "test",
        "Test",
        "Tests",
        "docs",
        "doc",
        "examples",
        "example",
        "fixtures",
        "benchmark",
        "benchmarks"
      ]
    }
  ],
  "exclude-dev-files": true
}